# Backend Environment Variables
# Update DATABASE_URL to your local PostgreSQL instance before running migrations.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/josanz_erp?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="no-reply@josanz.com"
SMTP_PASS="your-smtp-password"

# App
PORT=3000
NODE_ENV=development