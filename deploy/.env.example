# Copiar a deploy/.env en el servidor (no commitear secretos).
# DATABASE_URL debe apuntar al host `postgres` del compose (red interna Docker).
DATABASE_URL=postgresql://postgres:CAMBIAR@postgres:5432/josanz_erp?schema=public

POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR
POSTGRES_DB=josanz_erp

JWT_SECRET=CAMBIAR_MINIMO_32_CARACTERES
JWT_REFRESH_SECRET=OTRO_SECRETO_LARGO

# Origen del front (URL pública); lista separada por comas si hay varios
CORS_ORIGIN=https://erp.tudominio.com

# Imágenes publicadas por CI (GHCR exige owner/repo en minúsculas)
BACKEND_IMAGE=ghcr.io/tu-org/tu-repo/backend:main
FRONTEND_IMAGE=ghcr.io/tu-org/tu-repo/frontend:main

HTTP_PORT=80
