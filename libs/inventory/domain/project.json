{
  "name": "inventory-core",
  "$schema": "../../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/inventory/domain/src",
  "projectType": "library",
  "tags": ["scope:inventory", "type:core"],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "outputPath": "dist/libs/inventory/domain",
        "main": "libs/inventory/domain/src/index.ts",
        "tsConfig": "libs/inventory/domain/tsconfig.lib.json",
        "assets": []
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/inventory/domain/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/inventory/domain/jest.config.cts",
        "passWithNoTests": true
      },
      "outputs": [
        "{workspaceRoot}/coverage/libs/inventory/domain"
      ]
    }
  }
}

