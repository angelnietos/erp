{
  "name": "inventory-backend",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/inventory/backend/src",
  "projectType": "library",
  "tags": ["scope:inventory", "type:backend"],
  "targets": {
    "build": {
      "executor": "@nrwl/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/inventory/backend",
        "main": "libs/inventory/backend/src/index.ts",
        "tsConfig": "libs/inventory/backend/tsconfig.lib.json",
        "assets": []
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": ["libs/inventory/backend/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "options": {
        "jestConfig": "libs/inventory/backend/jest.config.cts",
        "passWithNoTests": true
      },
      "outputs": ["{workspaceRoot}/coverage/libs/inventory/backend"]
    }
  }
}