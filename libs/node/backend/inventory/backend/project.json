{
  "name": "inventory-backend",
  "$schema": "../../../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/node/backend/inventory/backend/src",
  "projectType": "library",
  "tags": ["scope:inventory", "type:backend"],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "outputPath": "dist/libs/node/backend/inventory/backend",
        "main": "libs/node/backend/inventory/backend/src/index.ts",
        "tsConfig": "libs/node/backend/inventory/backend/tsconfig.lib.json",
        "assets": []
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/node/backend/inventory/backend/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/node/backend/inventory/backend/jest.config.cts",
        "passWithNoTests": true
      },
      "outputs": [
        "{workspaceRoot}/coverage/libs/node/backend/inventory/backend"
      ]
    }
  }
}




