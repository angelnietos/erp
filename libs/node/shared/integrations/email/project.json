{
  "name": "shared-integrations-email",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/integrations/email/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:integrations"],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
       "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "outputPath": "dist/libs/shared/integrations/email",
        "main": "libs/shared/integrations/email/src/index.ts",
        "tsConfig": "libs/shared/integrations/email/tsconfig.lib.json",
        "assets": ["libs/shared/integrations/email/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/shared/integrations/email/jest.config.cts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
