{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "types": ["node"],
    "module": "commonjs",
    "moduleResolution": "node",
    "noPropertyAccessFromIndexSignature": false,
    "baseUrl": "."
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts", "jest.config.cts"]
}
