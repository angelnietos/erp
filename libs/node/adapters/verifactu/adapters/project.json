{
  "name": "verifactu-adapters",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/node/adapters/verifactu/adapters/src",
  "projectType": "library",
  "tags": ["scope:verifactu", "type:adapters"],
  "implicitDependencies": ["verifactu-core"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "tsConfig": "libs/node/adapters/verifactu/adapters/tsconfig.lib.json"
      },
      "dependsOn": ["^build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/verifactu/adapters/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/verifactu/adapters/jest.config.cts",
        "passWithNoTests": true
      },
      "outputs": ["{workspaceRoot}/coverage/libs/verifactu/adapters"]
    }
  }
}
