{
  "name": "shared-ui-shell",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/browser/shared/ui-shell/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": ["type:shell", "type:ui"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "tsConfig": "libs/browser/shared/ui-shell/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/browser/shared/ui-shell/jest.config.cts",
        "tsConfig": "libs/browser/shared/ui-shell/tsconfig.spec.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
