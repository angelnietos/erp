{
  "name": "shared-cqrs",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/cqrs/src",
  "projectType": "library",
  "tags": [
    "scope:shared",
    "type:cqrs"
  ],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/shared/cqrs",
        "main": "libs/shared/cqrs/src/index.ts",
        "tsConfig": "libs/shared/cqrs/tsconfig.lib.json",
        "assets": [
          "libs/shared/cqrs/*.md"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/shared/cqrs/jest.config.cts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}




