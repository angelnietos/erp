{
  "name": "identity-api",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/isomorphic/api/identity/api/src",
  "projectType": "library",
  "tags": [
    "scope:identity",
    "type:api"
  ],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/isomorphic/api/identity/api",
        "main": "libs/isomorphic/api/identity/api/src/index.ts",
        "tsConfig": "libs/isomorphic/api/identity/api/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/isomorphic/api/identity/api/jest.config.cts"
      }
    }
  }
}
