{
  "name": "receipts-api",
  "$schema": "../../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/isomorphic/api/receipts/api/src",
  "projectType": "library",
  "tags": ["scope:receipts", "type:api"],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/isomorphic/api/receipts/api",
        "main": "libs/isomorphic/api/receipts/api/src/index.ts",
        "tsConfig": "libs/isomorphic/api/receipts/api/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/isomorphic/api/receipts/api/jest.config.cts"
      }
    }
  }
}
