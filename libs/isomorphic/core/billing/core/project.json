{
  "name": "billing-core",
  "$schema": "../../../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/isomorphic/core/billing/core/src",
  "projectType": "library",
  "tags": ["scope:billing", "type:core"],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
       "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "outputPath": "dist/libs/isomorphic/core/billing/core",
        "main": "libs/isomorphic/core/billing/core/src/index.ts",
        "tsConfig": "libs/isomorphic/core/billing/core/tsconfig.lib.json",
        "assets": []
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/isomorphic/core/billing/core/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/isomorphic/core/billing/core/jest.config.cts",
        "passWithNoTests": true
      },
      "outputs": ["{workspaceRoot}/coverage/libs/isomorphic/core/billing/core"]
    }
  }
}



