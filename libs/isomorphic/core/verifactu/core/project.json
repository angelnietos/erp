{
  "name": "verifactu-core",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/isomorphic/core/verifactu/core/src",
  "projectType": "library",
  "tags": ["scope:verifactu", "type:core"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/verifactu/core",
        "main": "libs/isomorphic/core/verifactu/core/src/index.ts",
        "tsConfig": "libs/isomorphic/core/verifactu/core/tsconfig.lib.json",
        "assets": []
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/verifactu/core/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/verifactu/core/jest.config.cts",
        "passWithNoTests": true
      },
      "outputs": ["{workspaceRoot}/coverage/libs/verifactu/core"]
    }
  }
}
