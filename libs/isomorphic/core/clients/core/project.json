{
  "name": "clients-core",
  "$schema": "../../../../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/clients/domain/src",
  "projectType": "library",
  "tags": ["scope:clients", "type:core"],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "outputPath": "dist/libs/clients/domain",
        "main": "libs/clients/domain/src/index.ts",
        "tsConfig": "libs/clients/domain/tsconfig.lib.json",
        "assets": []
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/clients/domain/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "options": {
        "jestConfig": "libs/clients/domain/jest.config.cts",
        "passWithNoTests": true
      },
      "outputs": ["{workspaceRoot}/coverage/libs/clients/domain"]
    }
  }
}




