{
  "name": "ui-kit",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared/ui-kit/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [
    "scope:shared",
    "type:ui"
  ],
  "targets": {
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/shared/ui-kit/jest.config.cts",
        "tsConfig": "libs/shared/ui-kit/tsconfig.spec.json"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "libs/shared/ui-kit/.storybook",
        "browserTarget": "ui-kit:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": [
        "{options.outputDir}"
      ],
      "options": {
        "outputDir": "dist/storybook/ui-kit",
        "configDir": "libs/shared/ui-kit/.storybook",
        "browserTarget": "ui-kit:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c libs/shared/ui-kit/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": [
        "build-storybook"
      ],
      "options": {
        "buildTarget": "ui-kit:build-storybook",
        "staticFilePath": "dist/storybook/ui-kit",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "ui-kit:build-storybook:ci"
        }
      }
    }
  }
}
