VERIFACTU_DATABASE_URL="postgresql://postgres:postgres@localhost:5437/verifactu_db?schema=public"
# 3110 evita choque con Loki en Docker (mapas típicos 3100:3100).
VERIFACTU_PORT=3110
# Comma-separated browser origins allowed to call this API (dev default matches Angular on :4200).
# Use * to allow any origin (not recommended with credentials).
VERIFACTU_CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
VERIFACTU_MODE=mock
# En local con el Angular del ERP usa false: el SPA envía x-tenant-id pero no suele enviar x-api-key.
# Pon true en entornos cerrados y configura claves en BD + cabecera x-api-key en el cliente.
VERIFACTU_REQUIRE_API_KEY=false
VERIFACTU_API_KEY=vf_dev_josanz_key
VERIFACTU_AEAT_ENDPOINT=https://prewww2.aeat.es/wlpl/TIKE-CONT/ws/SistemaFacturacion/VerifactuSOAP
VERIFACTU_AEAT_WSDL_URL=https://prewww2.aeat.es/static_files/common/internet/dep/aplicaciones/es/aeat/tikeV1.0/cont/ws/SistemaFacturacion.wsdl
VERIFACTU_SELLER_NIF=B00000000
VERIFACTU_SELLER_NAME=Verifactu Tenant

