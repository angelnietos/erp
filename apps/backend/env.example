# Copiar a .env en esta carpeta (no commitear secretos reales).
# Ver también docs/RUNBOOK.md

# --- Base de datos ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/josanz_erp?schema=public"

# --- API ---
PORT=3000
NODE_ENV=development

# Orígenes CORS permitidos (uno o varios separados por coma). Producción: dominios reales del frontend.
CORS_ORIGIN=http://localhost:4200

# JWT (producción: usar secreto fuerte y rotación)
# JWT_SECRET=

# --- Límites públicos (0 = desactivado) ---
# Peticiones por IP y ventana de 60s al endpoint GET /api/health
RATE_LIMIT_HEALTH_PER_MINUTE=0
# Igual para POST /api/auth/login (fuerza bruta)
RATE_LIMIT_LOGIN_PER_MINUTE=0

# --- Dominio / integraciones ---
# Días de retención de filas en `domain_events`; el job semanal borra registros más antiguos. 0 = no purgar automáticamente.
DOMAIN_EVENTS_RETENTION_DAYS=365

# Cifrado de secretos de webhooks (obligatorio en prod si se registran webhooks)
# WEBHOOK_ENCRYPTION_KEY=<32 bytes base64>
