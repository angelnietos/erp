// apps/backend/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==== CLIENTS ==== //
model Client {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  description String?
  sector      String?
  companyId   String?   @map("company_id") // Placeholder for Multi-tenant
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  budgets     Budget[]
  rentals     Rental[]

  @@map("clients")
}

// ==== CATALOG & PRODUCTS ==== //
model Product {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  price       Float?
  
  inventory   Inventory?
  rentalItems RentalItem[]
  budgetItems BudgetItem[]
  inventoryReservations InventoryReservation[]
  inventoryMovements InventoryMovement[]

  @@map("products")
}

// ==== INVENTORY & RENTALS ==== //
model Inventory {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @unique @db.Uuid @map("product_id")
  totalStock  Int      @map("total_stock")
  status      String
  version     Int      @default(1) // For optimistic concurrency

  product     Product  @relation(fields: [productId], references: [id])
  
  @@map("inventory")
}

enum ReferenceType {
  BUDGET
  RENTAL
  DELIVERY
}

model InventoryReservation {
  id            String         @id @default(uuid()) @db.Uuid
  productId     String         @db.Uuid @map("product_id")
  quantity      Int
  startDate     DateTime       @map("start_date")
  endDate       DateTime       @map("end_date")
  referenceType ReferenceType @map("reference_type")
  referenceId   String?        @db.Uuid @map("reference_id")
  status        String

  product       Product        @relation(fields: [productId], references: [id])

  @@index([productId, startDate, endDate], name: "idx_inventory_reservations_lookup")
  @@map("inventory_reservations")
}

enum MovementType {
  IN
  OUT
  RESERVE
  RELEASE
}

model InventoryMovement {
  id          String        @id @default(uuid()) @db.Uuid
  productId   String        @db.Uuid @map("product_id")
  type        MovementType
  quantity    Int
  referenceId String?       @db.Uuid @map("reference_id")
  createdAt   DateTime      @default(now()) @map("created_at")

  product     Product       @relation(fields: [productId], references: [id])

  @@map("inventory_movements")
}

model Rental {
  id          String       @id @default(uuid()) @db.Uuid
  clientId    String       @db.Uuid @map("client_id")
  status      String
  createdAt   DateTime     @default(now()) @map("created_at")
  deletedAt   DateTime?    @map("deleted_at")

  client      Client       @relation(fields: [clientId], references: [id])
  rentalItems RentalItem[]

  @@map("rentals")
}

model RentalItem {
  id          String    @id @default(uuid()) @db.Uuid
  rentalId    String    @db.Uuid @map("rental_id")
  productId   String    @db.Uuid @map("product_id")
  quantity    Int
  unitId      String?   @db.Uuid @map("unit_id") // Optional tracking of physical unit

  rental      Rental    @relation(fields: [rentalId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])

  @@map("rental_items")
}

// ==== DOCUMENTS MODULE ==== //
model Budget {
  id             String          @id @default(uuid()) @db.Uuid
  clientId       String          @db.Uuid @map("client_id")
  startDate      DateTime        @map("start_date")
  endDate        DateTime        @map("end_date")
  total          Float           @default(0)
  status         String          @default("DRAFT")
  version        Int             @default(1)
  idempotencyKey String?         @map("idempotency_key")
  createdAt      DateTime        @default(now()) @map("created_at")

  client         Client          @relation(fields: [clientId], references: [id])
  items          BudgetItem[]
  deliveryNotes  DeliveryNote[]
  invoices       Invoice[]
  
  @@map("budgets")
}

model BudgetItem {
  id        String   @id @default(uuid()) @db.Uuid
  budgetId  String   @db.Uuid @map("budget_id")
  productId String   @db.Uuid @map("product_id")
  quantity  Int
  price     Float
  discount  Float    @default(0)
  tax       Float    @default(21)

  budget    Budget   @relation(fields: [budgetId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@map("budget_items")
}

model DeliveryNote {
  id               String   @id @default(uuid()) @db.Uuid
  budgetId         String   @db.Uuid @map("budget_id")
  signatureBlobUrl String?  @map("signature_blob_url")
  status           String
  createdAt        DateTime @default(now()) @map("created_at")

  budget           Budget   @relation(fields: [budgetId], references: [id])

  @@map("delivery_notes")
}

model Invoice {
  id              String   @id @default(uuid()) @db.Uuid
  budgetId        String   @db.Uuid @map("budget_id")
  tenantId        String?  @db.Uuid @map("tenant_id")
  total           Float
  verifactuStatus String   @default("PENDING") @map("verifactu_status")
  currentHash     String?  @map("current_hash")
  previousHash    String?  @map("previous_hash")
  createdAt       DateTime @default(now()) @map("created_at")

  budget          Budget   @relation(fields: [budgetId], references: [id])
  tenant          Tenant?  @relation(fields: [tenantId], references: [id])
  verifactuLogs   VerifactuLog[]
  queueItems      VerifactuQueueItem[]

  @@map("invoices")
}

model VerifactuLog {
  id              String   @id @default(uuid()) @db.Uuid
  invoiceId       String   @db.Uuid @map("invoice_id")
  tenantId        String   @db.Uuid @map("tenant_id")
  requestPayload  Json     @map("request_payload")
  responsePayload Json     @map("response_payload")
  status          String
  errorMessage    String?  @map("error_message")
  createdAt       DateTime @default(now()) @map("created_at")

  invoice         Invoice  @relation(fields: [invoiceId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@map("verifactu_logs")
}

model Tenant {
  id               String                   @id @default(uuid()) @db.Uuid
  name             String
  slug             String                   @unique
  isActive         Boolean                  @default(true) @map("is_active")
  createdAt        DateTime                 @default(now()) @map("created_at")

  invoices         Invoice[]
  verifactuLogs    VerifactuLog[]
  apiKeys          TenantApiKey[]
  webhookEndpoints VerifactuWebhookEndpoint[]
  webhookDeliveries VerifactuWebhookDelivery[]
  queueItems        VerifactuQueueItem[]
  series            VerifactuSeries[]
  customers         VerifactuCustomer[]

  @@map("tenants")
}

model TenantApiKey {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid @map("tenant_id")
  keyHash    String   @map("key_hash")
  scopes     String[]
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, keyHash], name: "idx_tenant_api_key_lookup")
  @@map("tenant_api_keys")
}

model VerifactuWebhookEndpoint {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @db.Uuid @map("tenant_id")
  eventType  String   @map("event_type")
  url        String
  secret     String
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  deliveries VerifactuWebhookDelivery[]

  @@index([tenantId, eventType], name: "idx_verifactu_webhook_endpoints_lookup")
  @@map("verifactu_webhook_endpoints")
}

model VerifactuWebhookDelivery {
  id             String   @id @default(uuid()) @db.Uuid
  endpointId     String   @db.Uuid @map("endpoint_id")
  tenantId       String   @db.Uuid @map("tenant_id")
  eventType      String   @map("event_type")
  payload        Json
  status         String
  statusCode     Int      @default(0) @map("status_code")
  responsePayload Json?   @map("response_payload")
  createdAt      DateTime @default(now()) @map("created_at")

  endpoint       VerifactuWebhookEndpoint @relation(fields: [endpointId], references: [id])
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, eventType], name: "idx_verifactu_webhook_deliveries_lookup")
  @@map("verifactu_webhook_deliveries")
}

model VerifactuQueueItem {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @db.Uuid @map("tenant_id")
  invoiceId     String   @db.Uuid @map("invoice_id")
  status        String   @default("PENDING")
  retries       Int      @default(0)
  maxRetries    Int      @default(5) @map("max_retries")
  nextRetryAt   DateTime? @map("next_retry_at")
  lastError     String?  @map("last_error")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])

  @@index([status, nextRetryAt], name: "idx_verifactu_queue_status_retry")
  @@map("verifactu_queue_items")
}

model VerifactuSeries {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  code        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code], name: "uq_verifactu_series_tenant_code")
  @@map("verifactu_series")
}

model VerifactuCustomer {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  taxId       String   @map("tax_id")
  name        String
  email       String?
  countryCode String?  @map("country_code")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, taxId], name: "uq_verifactu_customer_tenant_taxid")
  @@index([tenantId, name], name: "idx_verifactu_customer_tenant_name")
  @@map("verifactu_customers")
}

// ==== RELIABILITY / ASYNC ==== //
model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @db.Uuid @map("aggregate_id")
  eventType     String    @map("event_type")
  payload       Json
  status        String    @default("PENDING") // pending, processed, failed
  retries       Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  processedAt   DateTime? @map("processed_at")

  @@map("outbox_events")
}

model IdempotencyKey {
  key          String   @id
  scope        String
  responseJson Json     @map("response_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("idempotency_keys")
}

// ==== FLEET & AUDIT ==== //
model Vehicle {
  id               String    @id @default(uuid()) @db.Uuid
  plate            String    @unique
  brand            String
  model            String
  type             String
  capacity         Int
  year             Int
  status           String    @default("AVAILABLE")
  mileage          Int       @default(0)
  lastMaintenance  DateTime? @map("last_maintenance")
  nextMaintenance  DateTime? @map("next_maintenance")
  insuranceExpiry  DateTime  @map("insurance_expiry")
  notes            String?
  version          Int       @default(1)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("vehicles")
}

model Driver {
  id            String    @id @default(uuid()) @db.Uuid
  employeeId    String    @unique @map("employee_id")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  nif           String    @unique
  phone         String
  email         String
  licenseType   String    @map("license_type")
  licenseNumber String    @map("license_number")
  licenseExpiry DateTime  @map("license_expiry")
  status        String    @default("ACTIVE")
  hireDate      DateTime  @map("hire_date")
  notes         String?
  version       Int       @default(1)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("drivers")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid @map("user_id")
  action         String
  targetEntity   String   @map("target_entity")
  correlationId  String   @map("correlation_id")
  changesJson    Json     @map("changes_json")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model User {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @unique
  password  String
  firstName String?   @map("first_name")
  lastName  String?   @map("last_name")
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")
  roles     UserRole[]

  @@map("users")
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  permissions String[]
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  userId String @db.Uuid @map("user_id")
  roleId String @db.Uuid @map("role_id")
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}
