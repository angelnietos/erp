generator client {
  provider = "prisma-client-js"
  // Hoist generated client to workspace root so TypeScript resolves `.prisma/client` from `@prisma/client` (pnpm layout).
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String
  description String?
  sector      String?
  type        String    @default("COMPANY") // COMPANY or INDIVIDUAL
  taxId       String?   @map("tax_id")
  email       String?
  phone       String?
  address     String?
  city        String?
  zipCode     String?   @map("zip_code")
  country     String?   @default("ES")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  contacts    ClientContact[]
  eventReports EventReport[]
  budgets     Budget[]
  events      Event[]
  projects    Project[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  rentals     Rental[]

  @@map("clients")
}

model ClientContact {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  email     String?
  phone     String?
  position  String?
  notes     String?
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@map("client_contacts")
}

model Product {
  id                    String                 @id @default(uuid()) @db.Uuid
  tenantId              String                 @map("tenant_id") @db.Uuid
  name                  String
  sku                   String?                @unique
  category              String?
  categoryId            String?                @map("category_id") @db.Uuid
  type                  String?                @default("generic")
  ownership             String                 @default("OWN") // OWN or RENTED
  description           String?
  price                 Float?
  dailyRate             Float?                 @map("daily_rate")
  imageUrl              String?                @map("image_url")
  serialNumber          String?                @map("serial_number")
  budgetItems           BudgetItem[]
  inventory             Inventory?
  inventoryMovements    InventoryMovement[]
  inventoryReservations InventoryReservation[]
  damages               DamageReport[]
  categoryRef           Category?              @relation(fields: [categoryId], references: [id])
  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  rentalItems           RentalItem[]

  @@map("products")
}

model Inventory {
  id         String  @id @default(uuid()) @db.Uuid
  productId  String  @unique @map("product_id") @db.Uuid
  totalStock Int     @map("total_stock")
  status     String
  version    Int     @default(1)
  product    Product @relation(fields: [productId], references: [id])

  @@map("inventory")
}

model InventoryReservation {
  id            String        @id @default(uuid()) @db.Uuid
  productId     String        @map("product_id") @db.Uuid
  quantity      Int
  startDate     DateTime      @map("start_date")
  endDate       DateTime      @map("end_date")
  referenceType ReferenceType @map("reference_type")
  referenceId   String?       @map("reference_id") @db.Uuid
  status        String
  product       Product       @relation(fields: [productId], references: [id])

  @@index([productId, startDate, endDate], map: "idx_inventory_reservations_lookup")
  @@map("inventory_reservations")
}

model InventoryMovement {
  id          String       @id @default(uuid()) @db.Uuid
  productId   String       @map("product_id") @db.Uuid
  type        MovementType
  quantity    Int
  referenceId String?      @map("reference_id") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at")
  product     Product      @relation(fields: [productId], references: [id])

  @@map("inventory_movements")
}

model Rental {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  reference       String?       @unique
  clientId        String        @map("client_id") @db.Uuid
  startDate       DateTime?     @map("start_date")
  endDate         DateTime?     @map("end_date")
  pickupLocation  String?       @map("pickup_location")
  dropoffLocation String?       @map("dropoff_location")
  totalPrice      Float?        @map("total_price")
  notes           String?
  status          String        @default("pending")
  signatureStatus String        @default("NONE") @map("signature_status")
  signedAt        DateTime?     @map("signed_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  deletedAt       DateTime?     @map("deleted_at")
  rentalItems     RentalItem[]
  rentalAnnexes   RentalAnnex[]
  client          Client        @relation(fields: [clientId], references: [id])
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@map("rentals")
}

model RentalAnnex {
  id          String   @id @default(uuid()) @db.Uuid
  rentalId    String   @map("rental_id") @db.Uuid
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  rental      Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@index([rentalId])
  @@map("rental_annexes")
}

model RentalItem {
  id        String  @id @default(uuid()) @db.Uuid
  rentalId  String  @map("rental_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  quantity  Int
  unitId    String? @map("unit_id") @db.Uuid
  product   Product @relation(fields: [productId], references: [id])
  rental    Rental  @relation(fields: [rentalId], references: [id])

  @@map("rental_items")
}

model Budget {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  clientId       String         @map("client_id") @db.Uuid
  eventId        String?        @map("event_id") @db.Uuid
  startDate      DateTime       @map("start_date")
  endDate        DateTime       @map("end_date")
  total          Float          @default(0)
  status         String         @default("DRAFT")
  version        Int            @default(1)
  idempotencyKey String?        @map("idempotency_key")
  createdAt      DateTime       @default(now()) @map("created_at")
  items          BudgetItem[]
  client         Client         @relation(fields: [clientId], references: [id])
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  event          Event?         @relation(fields: [eventId], references: [id])
  deliveryNotes  DeliveryNote[]
  invoices       Invoice[]

  @@map("budgets")
}

model BudgetItem {
  id        String  @id @default(uuid()) @db.Uuid
  budgetId  String  @map("budget_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  quantity  Int
  price     Float
  discount  Float   @default(0)
  tax       Float   @default(21)
  budget    Budget  @relation(fields: [budgetId], references: [id])
  product   Product @relation(fields: [productId], references: [id])

  @@map("budget_items")
}

model DeliveryNote {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  budgetId         String   @map("budget_id") @db.Uuid
  signatureBlobUrl String?  @map("signature_blob_url")
  status           String
  createdAt        DateTime @default(now()) @map("created_at")
  budget           Budget   @relation(fields: [budgetId], references: [id])
  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  @@map("delivery_notes")
}

model Invoice {
  id              String               @id @default(uuid()) @db.Uuid
  budgetId        String               @map("budget_id") @db.Uuid
  tenantId        String?              @map("tenant_id") @db.Uuid
  invoiceNumber   String               @unique @map("invoice_number")
  status          String               @default("DRAFT")
  type            String               @default("NORMAL")
  issueDate       DateTime             @default(now()) @map("issue_date")
  dueDate         DateTime             @default(now()) @map("due_date")
  total           Float
  verifactuStatus String               @default("PENDING") @map("verifactu_status")
  currentHash     String?              @map("current_hash")
  previousHash    String?              @map("previous_hash")
  createdAt       DateTime             @default(now()) @map("created_at")
  budget          Budget               @relation(fields: [budgetId], references: [id])
  tenant          Tenant?              @relation(fields: [tenantId], references: [id])
  verifactuLogs   VerifactuLog[]
  queueItems      VerifactuQueueItem[]
  erpReceipts     ErpReceipt[]

  @@map("invoices")
}

model VerifactuLog {
  id              String   @id @default(uuid()) @db.Uuid
  invoiceId       String   @map("invoice_id") @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  requestPayload  Json     @map("request_payload")
  responsePayload Json     @map("response_payload")
  status          String
  errorMessage    String?  @map("error_message")
  createdAt       DateTime @default(now()) @map("created_at")
  invoice         Invoice  @relation(fields: [invoiceId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@map("verifactu_logs")
}

model Tenant {
  id                           String                       @id @default(uuid()) @db.Uuid
  name                         String
  slug                         String                       @unique
  isActive                     Boolean                      @default(true) @map("is_active")
  createdAt                    DateTime                     @default(now()) @map("created_at")
  budgets                      Budget[]
  clients                      Client[]
  deliveryNotes                DeliveryNote[]
  invoices                     Invoice[]
  products                     Product[]
  rentals                      Rental[]
  vehicles                     Vehicle[]
  categories                   Category[]
  events                       Event[]
  technicians                  Technician[]
  drivers                      Driver[]
  projects                     Project[]
  damageReports                DamageReport[]
  apiKeys                      TenantApiKey[]
  users                        User[]
  customers                    VerifactuCustomer[]
  verifactuLogs                VerifactuLog[]
  queueItems                   VerifactuQueueItem[]
  series                       VerifactuSeries[]
  webhookDeliveries            VerifactuWebhookDelivery[]
  webhookEndpoints             VerifactuWebhookEndpoint[]
  erpReceipts                  ErpReceipt[]
  domainEventRecords           DomainEventRecord[]
  integrationWebhooks          IntegrationWebhook[]
  technicianAvailability       TechnicianAvailability[]
  integrationWebhookDeliveries IntegrationWebhookDelivery[]
  integrationWebhookQueue      IntegrationWebhookQueueItem[]
  aiInsights                   AiInsight[]
  clientContacts               ClientContact[]
  eventReports                 EventReport[]
  roles                        Role[]

  @@map("tenants")
}

model TenantApiKey {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  keyHash   String   @map("key_hash")
  scopes    String[]
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, keyHash], map: "idx_tenant_api_key_lookup")
  @@map("tenant_api_keys")
}

model VerifactuWebhookEndpoint {
  id         String                     @id @default(uuid()) @db.Uuid
  tenantId   String                     @map("tenant_id") @db.Uuid
  eventType  String                     @map("event_type")
  url        String
  secret     String
  isActive   Boolean                    @default(true) @map("is_active")
  createdAt  DateTime                   @default(now()) @map("created_at")
  deliveries VerifactuWebhookDelivery[]
  tenant     Tenant                     @relation(fields: [tenantId], references: [id])

  @@index([tenantId, eventType], map: "idx_verifactu_webhook_endpoints_lookup")
  @@map("verifactu_webhook_endpoints")
}

model VerifactuWebhookDelivery {
  id              String                   @id @default(uuid()) @db.Uuid
  endpointId      String                   @map("endpoint_id") @db.Uuid
  tenantId        String                   @map("tenant_id") @db.Uuid
  eventType       String                   @map("event_type")
  payload         Json
  status          String
  statusCode      Int                      @default(0) @map("status_code")
  responsePayload Json?                    @map("response_payload")
  createdAt       DateTime                 @default(now()) @map("created_at")
  endpoint        VerifactuWebhookEndpoint @relation(fields: [endpointId], references: [id])
  tenant          Tenant                   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, eventType], map: "idx_verifactu_webhook_deliveries_lookup")
  @@map("verifactu_webhook_deliveries")
}

model VerifactuQueueItem {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  invoiceId   String    @map("invoice_id") @db.Uuid
  status      String    @default("PENDING")
  retries     Int       @default(0)
  maxRetries  Int       @default(5) @map("max_retries")
  nextRetryAt DateTime? @map("next_retry_at")
  lastError   String?   @map("last_error")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  invoice     Invoice   @relation(fields: [invoiceId], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@index([status, nextRetryAt], map: "idx_verifactu_queue_status_retry")
  @@map("verifactu_queue_items")
}

model VerifactuSeries {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  code        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code], name: "uq_verifactu_series_tenant_code")
  @@map("verifactu_series")
}

model VerifactuCustomer {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  taxId       String   @map("tax_id")
  name        String
  email       String?
  countryCode String?  @map("country_code")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, taxId], name: "uq_verifactu_customer_tenant_taxid")
  @@index([tenantId, name], map: "idx_verifactu_customer_tenant_name")
  @@map("verifactu_customers")
}

model OutboxEvent {
  id            String    @id @default(uuid()) @db.Uuid
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id") @db.Uuid
  eventType     String    @map("event_type")
  payload       Json
  status        String    @default("PENDING")
  retries       Int       @default(0)
  createdAt     DateTime  @default(now()) @map("created_at")
  processedAt   DateTime? @map("processed_at")

  @@map("outbox_events")
}

model IdempotencyKey {
  key          String   @id
  scope        String
  responseJson Json     @map("response_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("idempotency_keys")
}

model Vehicle {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  name            String
  plate           String    @unique
  type            String
  capacity        Float
  status          String    @default("available")
  location        String?
  nextMaintenance DateTime? @map("next_maintenance")
  driverId        String?   @map("driver_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @map("updated_at")
  driver          Driver?   @relation(fields: [driverId], references: [id])
  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  @@map("vehicles")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  action        String
  targetEntity  String   @map("target_entity")
  correlationId String   @map("correlation_id")
  changesJson   Json     @map("changes_json")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

model Category {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  name        String
  description String?
  type        String? // PRODUCT, SERVICE
  parentId    String?    @map("parent_id") @db.Uuid
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("categories")
}

model Event {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  name        String
  clientId    String?           @map("client_id") @db.Uuid
  startDate   DateTime          @map("start_date")
  endDate     DateTime          @map("end_date")
  summary     String?
  status      String            @default("PLANNED")
  location    String?
  notes       String?
  budgets     Budget[]
  projects    ProjectEvent[]
  technicians EventTechnician[]
  reports     EventReport[]
  client      Client?           @relation(fields: [clientId], references: [id])
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  createdAt   DateTime          @default(now()) @map("created_at")

  @@map("events")
}

model EventReport {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  title     String
  content   String   @db.Text
  authorId  String?  @map("author_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  author    User?    @relation(fields: [authorId], references: [id])

  @@map("event_reports")
}

model Technician {
  id                    String                   @id @default(uuid()) @db.Uuid
  tenantId              String                   @map("tenant_id") @db.Uuid
  userId                String                   @unique @map("user_id") @db.Uuid
  bio                   String?                  @db.Text
  avatarUrl             String?                  @map("avatar_url")
  hourlyRate            Float                    @map("hourly_rate")
  skills                String[]
  status                String                   @default("ACTIVE")
  user                  User                     @relation(fields: [userId], references: [id])
  tenant                Tenant                   @relation(fields: [tenantId], references: [id])
  events                EventTechnician[]
  availability          TechnicianAvailability[]
  createdAt             DateTime                 @default(now()) @map("created_at")

  @@map("technicians")
}

model TechnicianAvailability {
  id           String     @id @default(uuid()) @db.Uuid
  technicianId String     @map("technician_id") @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  startDate    DateTime   @map("start_date")
  endDate      DateTime   @map("end_date")
  type         String     @default("AVAILABLE") // AVAILABLE, BUSY, HOLIDAY, SICK
  notes        String?
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  tenant       Tenant     @relation(fields: [tenantId], references: [id])

  @@index([technicianId, startDate, endDate], map: "idx_technician_availability_lookup")
  @@map("technician_availability")
}

model EventTechnician {
  eventId      String     @map("event_id") @db.Uuid
  technicianId String     @map("technician_id") @db.Uuid
  assignedAt   DateTime   @default(now()) @map("assigned_at")
  event        Event      @relation(fields: [eventId], references: [id])
  technician   Technician @relation(fields: [technicianId], references: [id])

  @@id([eventId, technicianId])
  @@map("event_technicians")
}

model Driver {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  userId        String?   @unique @map("user_id") @db.Uuid
  name          String
  licenseNumber String    @map("license_number")
  licenseType   String    @map("license_type")
  status        String    @default("ACTIVE")
  user          User?     @relation(fields: [userId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  vehicles      Vehicle[]
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("drivers")
}

model Project {
  id          String         @id @default(uuid()) @db.Uuid
  tenantId    String         @map("tenant_id") @db.Uuid
  name        String
  description String?
  status      String         @default("ACTIVE")
  startDate   DateTime?      @map("start_date")
  endDate     DateTime?      @map("end_date")
  clientId    String?        @map("client_id") @db.Uuid
  events      ProjectEvent[]
  client      Client?        @relation(fields: [clientId], references: [id])
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  createdAt   DateTime       @default(now()) @map("created_at")

  @@map("projects")
}

model ProjectEvent {
  projectId String  @map("project_id") @db.Uuid
  eventId   String  @map("event_id") @db.Uuid
  project   Project @relation(fields: [projectId], references: [id])
  event     Event   @relation(fields: [eventId], references: [id])

  @@id([projectId, eventId])
  @@map("project_events")
}

model DamageReport {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  productId   String   @map("product_id") @db.Uuid
  reportedBy  String   @map("reported_by") @db.Uuid
  reportDate  DateTime @default(now()) @map("report_date")
  place       String
  description String
  status      String   @default("REPORTED")
  images      String[]
  repairCost  Float?   @map("repair_cost")
  product     Product  @relation(fields: [productId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  reporter    User     @relation(fields: [reportedBy], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("damage_reports")
}

model User {
  id            String         @id @default(uuid()) @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  email         String
  password      String
  firstName     String?        @map("first_name")
  lastName      String?        @map("last_name")
  isActive      Boolean        @default(true) @map("is_active")
  category      String?        @map("category")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime?      @map("updated_at")
  roles         UserRole[]
  technician    Technician?
  driver        Driver?
  damageReports DamageReport[]
  tenant        Tenant         @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@map("users")
  eventReports  EventReport[]
}

model Role {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String?    @map("tenant_id") @db.Uuid
  name        String     
  description String?
  type        RoleType   @default(USER)
  permissions String[]
  users       UserRole[]
  tenant      Tenant?    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name], name: "tenantId_name")
  @@map("roles")
}

enum RoleType {
  SUPERADMIN
  ADMIN
  RESPONSIBLE
  USER
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

/// Recibos ERP (Fase 4) — desacoplado de factura real; invoiceId es referencia lógica.
model ErpReceipt {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  invoiceId     String    @map("invoice_id") @db.Uuid
  amount        Float
  currency      String    @default("EUR")
  status        String    @default("PENDING")
  paymentMethod String?   @map("payment_method")
  paymentDate   DateTime? @map("payment_date")
  dueDate       DateTime  @map("due_date")
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  invoice       Invoice   @relation(fields: [invoiceId], references: [id])

  @@index([tenantId, status], map: "idx_erp_receipts_tenant_status")
  @@index([tenantId, dueDate], map: "idx_erp_receipts_tenant_due")
  @@index([invoiceId], map: "idx_erp_receipts_invoice")
  @@map("erp_receipts")
}

model DomainEventRecord {
  id                String                       @id @default(uuid()) @db.Uuid
  tenantId          String                       @map("tenant_id") @db.Uuid
  eventType         String                       @map("event_type")
  aggregateType     String                       @map("aggregate_type")
  aggregateId       String                       @map("aggregate_id")
  payload           Json
  createdByUserId   String?                      @map("created_by_user_id") @db.Uuid
  createdAt         DateTime                     @default(now()) @map("created_at")
  tenant            Tenant                       @relation(fields: [tenantId], references: [id])
  webhookDeliveries IntegrationWebhookDelivery[]
  webhookQueueItems IntegrationWebhookQueueItem[]

  @@index([tenantId, createdAt(sort: Desc)], map: "idx_domain_events_tenant_created")
  @@map("domain_events")
}

model IntegrationWebhook {
  id         String                       @id @default(uuid()) @db.Uuid
  tenantId   String                       @map("tenant_id") @db.Uuid
  url        String
  secret     String
  eventTypes Json                         @map("event_types")
  isActive   Boolean                      @default(true) @map("is_active")
  createdAt  DateTime                     @default(now()) @map("created_at")
  updatedAt  DateTime                     @updatedAt @map("updated_at")
  tenant     Tenant                       @relation(fields: [tenantId], references: [id])
  deliveries IntegrationWebhookDelivery[]
  queueItems IntegrationWebhookQueueItem[]

  @@index([tenantId], map: "idx_integration_webhooks_tenant")
  @@map("integration_webhooks")
}

model IntegrationWebhookDelivery {
  id            String             @id @default(uuid()) @db.Uuid
  webhookId     String             @map("webhook_id") @db.Uuid
  tenantId      String             @map("tenant_id") @db.Uuid
  domainEventId String?            @map("domain_event_id") @db.Uuid
  eventType     String             @map("event_type")
  status        String
  statusCode    Int                @default(0) @map("status_code")
  responseBody  String?            @map("response_body") @db.Text
  createdAt     DateTime           @default(now()) @map("created_at")
  webhook       IntegrationWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  domainEvent   DomainEventRecord? @relation(fields: [domainEventId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)], map: "idx_webhook_deliveries_tenant_created")
  @@map("integration_webhook_deliveries")
}

model IntegrationWebhookQueueItem {
  id           String             @id @default(uuid()) @db.Uuid
  webhookId    String             @map("webhook_id") @db.Uuid
  tenantId     String             @map("tenant_id") @db.Uuid
  domainEventId String             @map("domain_event_id") @db.Uuid
  status       String             @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  retries      Int                @default(0)
  maxRetries   Int                @default(5) @map("max_retries")
  nextRetryAt  DateTime?          @map("next_retry_at")
  lastError    String?            @map("last_error") @db.Text
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  webhook      IntegrationWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  domainEvent  DomainEventRecord  @relation(fields: [domainEventId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt], map: "idx_webhook_queue_status_retry")
  @@map("integration_webhook_queue")
}

model AiInsight {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  botId     String   @map("bot_id")
  feature   String   
  title     String
  summary   String   @db.Text
  metrics   Json?
  metadata  Json?
  priority  String   @default("MEDIUM")
  status    String   @default("NEW")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, botId], map: "idx_ai_insights_tenant_bot")
  @@index([tenantId, createdAt(sort: Desc)], map: "idx_ai_insights_tenant_created")
  @@map("ai_insights")
}

enum ReferenceType {
  BUDGET
  RENTAL
  DELIVERY
}

enum MovementType {
  IN
  OUT
  RESERVE
  RELEASE
}
