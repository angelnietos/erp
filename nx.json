{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "master",
  "analytics": false,
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/.eslintrc.json",
      "!{projectRoot}/eslint.config.mjs",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/jest.config.[jt]s",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/test-setup.[jt]s",
      "!{projectRoot}/**/*.stories.@(js|jsx|ts|tsx|mdx)",
      "!{projectRoot}/.storybook/**/*",
      "!{projectRoot}/tsconfig.storybook.json"
    ],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "@angular/build:application": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "@nx/eslint:lint": {
      "cache": true,
      "inputs": [
        "default",
        "{workspaceRoot}/.eslintrc.json",
        "{workspaceRoot}/.eslintignore",
        "{workspaceRoot}/eslint.config.mjs"
      ]
    },
    "@nx/jest:jest": {
      "cache": true,
      "inputs": ["default", "^production", "{workspaceRoot}/jest.preset.js"],
      "options": {
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "@nx/js:tsc": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "@nx/angular:package": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "build-storybook": {
      "cache": true,
      "inputs": [
        "default",
        "^production",
        "{projectRoot}/.storybook/**/*",
        "{projectRoot}/tsconfig.storybook.json"
      ]
    }
  },
  "plugins": [
    {
      "plugin": "@nx/playwright/plugin",
      "options": {
        "targetName": "e2e"
      }
    },
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/webpack/plugin",
      "options": {
        "buildTargetName": "build",
        "serveTargetName": "serve",
        "previewTargetName": "preview",
        "buildDepsTargetName": "build-deps",
        "watchDepsTargetName": "watch-deps",
        "serveStaticTargetName": "serve-static"
      }
    }
  ],
  "generators": {
    "@nx/angular:application": {
      "e2eTestRunner": "playwright",
      "linter": "eslint",
      "style": "css",
      "unitTestRunner": "jest"
    },
    "@nx/angular:library": {
      "linter": "eslint",
      "unitTestRunner": "jest"
    },
    "@nx/angular:component": {
      "style": "css"
    }
  },
  "targetDependencies": {
    "build": [
      {
        "target": "build",
        "projects": "dependencies"
      }
    ],
    "lint": [
      {
        "target": "lint",
        "projects": "self"
      }
    ]
  },
  "release": {
    "projects": ["*"]
  },
  "pluginsConfig": {
    "@nx/angular": {
      "targetBuildTargetDependencies": {
        "build": [
          {
            "target": "build",
            "projects": "dependencies"
          }
        ]
      }
    }
  },
  "constraints": {
    "allowed": {
      "tags": []
    },
    "sourceTags": {
      "type:core": {
        "description": "Pure domain models (entities, value objects, ports)",
        "onAllow": {
          "actions": ["*"]
        }
      },
      "type:backend": {
        "description": "Backend implementation (controllers, services, modules)",
        "onAllow": {
          "actions": ["*"]
        }
      },
      "type:api": {
        "description": "Frontend API client (HTTP infrastructure)",
        "onAllow": {
          "actions": ["*"]
        }
      },
      "type:data-access": {
        "description": "Frontend data access (state management, services)",
        "onAllow": {
          "actions": ["*"]
        }
      },
      "type:feature": {
        "description": "Frontend feature components (pages, containers)",
        "onAllow": {
          "actions": ["*"]
        }
      },
      "type:shell": {
        "description": "Frontend shell (routing, composition)",
        "onAllow": {
          "actions": ["*"]
        }
      },
      "scope:shared": {
        "description": "Shared utilities and infrastructure",
        "onAllow": {
          "actions": ["*"]
        }
      },
      "type:app": {
        "description": "Applications (can depend on all libs)",
        "onAllow": {
          "actions": ["*"]
        }
      },
      "scope:backend": {
        "description": "Backend Workspace App Layer",
        "onAllow": {
          "actions": ["*"]
        }
      }
    },
    "dependencies": [
      {
        "sourceTag": "type:feature",
        "onlyDependOnLibsWithTags": [
          "type:data-access",
          "type:shell",
          "scope:shared"
        ]
      },
      {
        "sourceTag": "type:data-access",
        "onlyDependOnLibsWithTags": ["type:api", "type:core", "scope:shared"]
      },
      {
        "sourceTag": "type:api",
        "onlyDependOnLibsWithTags": ["type:core", "scope:shared"]
      },
      {
        "sourceTag": "type:shell",
        "onlyDependOnLibsWithTags": ["type:feature", "scope:shared"]
      },
      {
        "sourceTag": "type:backend",
        "onlyDependOnLibsWithTags": ["type:core", "scope:shared", "type:data-access", "type:adapters"]
      },
      {
        "sourceTag": "type:app",
        "onlyDependOnLibsWithTags": ["*"]
      },
      {
        "sourceTag": "scope:backend",
        "onlyDependOnLibsWithTags": ["*"]
      },
      {
        "sourceTag": "*",
        "onlyDependOnLibsWithTags": ["*"]
      },
      {
        "sourceTag": "type:core",
        "onlyDependOnLibsWithTags": ["scope:shared"]
      }
    ]
  }
}
